{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "calendar-redirect",
  "main": "src/index.js",
  "compatibility_date": "2026-07-02",
  "observability": {
    "enabled": true
  },
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    { "pattern": "meet.bcause.com/*", "zone_name": "bcause.com" }
  ]
}
